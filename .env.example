# Template de variáveis de ambiente para o deploy em container.
# Copie para .env e preencha com as credenciais reais.
# .env está no .gitignore e no .dockerignore — NUNCA é commitado nem entra na imagem.
#
# Uso local:   docker run --env-file .env ...
# No ECS:      cada chave vira uma entrada em "environment" da Task Definition.

SNOWFLAKE_ACCOUNT=SEU_ACCOUNT_IDENTIFIER
SNOWFLAKE_USER=SEU_USUARIO
SNOWFLAKE_PASSWORD=SUA_SENHA
SNOWFLAKE_ROLE=SEU_ROLE
SNOWFLAKE_WAREHOUSE=SEU_WAREHOUSE
SNOWFLAKE_DATABASE=BASES_SPDO
SNOWFLAKE_SCHEMA=DB_GESTAO_BANCO_PRECO_APP_CONSULTA
