# Template — copie para .streamlit/secrets.toml e preencha com as credenciais reais.
# O arquivo .streamlit/secrets.toml NUNCA deve ser commitado (já está no .gitignore).
#
# No Streamlit Community Cloud, configurar em:
#   App settings -> Secrets

[snowflake]
account   = "SEU_ACCOUNT_IDENTIFIER"
user      = "SEU_USUARIO"
password  = "SUA_SENHA"
role      = "SEU_ROLE"
warehouse = "SEU_WAREHOUSE"
database  = "BASES_SPDO"
schema    = "DB_GESTAO_BANCO_PRECO_APP_CONSULTA"
